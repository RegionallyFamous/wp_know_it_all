{
  "name": "@wp-know-it-all/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "eval:quality": "tsx evals/run-evals.ts",
    "eval:canary": "EVAL_PROFILE=canary tsx evals/run-evals.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/cookie-parser": "^1.4.10",
    "@wp-know-it-all/shared": "workspace:*",
    "better-sqlite3": "^11.9.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "php-parser": "^3.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
