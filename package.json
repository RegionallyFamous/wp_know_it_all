{
  "name": "wp-know-it-all",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev:server": "turbo run dev --filter=@wp-know-it-all/server",
    "dev:scraper": "turbo run dev --filter=@wp-know-it-all/scraper",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"packages/**/src/**/*.ts\"",
    "ci": "turbo run build typecheck lint test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
