{
  "name": "wp-know-it-all",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev:server": "turbo run dev --filter=@wp-know-it-all/server",
    "dev:scraper": "turbo run dev --filter=@wp-know-it-all/scraper",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:strict": "turbo run lint -- --max-warnings=0",
    "test": "turbo run test",
    "eval:quality": "pnpm --filter @wp-know-it-all/server eval:quality",
    "eval:canary": "pnpm --filter @wp-know-it-all/server eval:canary",
    "eval:baseline": "pnpm --filter @wp-know-it-all/server eval:baseline",
    "eval:ops": "pnpm --filter @wp-know-it-all/server eval:ops",
    "format": "prettier --write \"packages/**/src/**/*.ts\"",
    "ci": "pnpm run build && pnpm run typecheck && pnpm run lint:strict && pnpm run test && pnpm run eval:quality && pnpm run eval:canary",
    "backup:db": "./scripts/backup-db.sh",
    "restore:db": "./scripts/restore-db.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
